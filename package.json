{
  "name": "lovie-p2p-request",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
