generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecipientContactType {
  EMAIL @map("email")
  PHONE @map("phone")
}

enum RequestStatus {
  PENDING   @map("Pending")
  PAID      @map("Paid")
  DECLINED  @map("Declined")
  CANCELLED @map("Cancelled")
  EXPIRED   @map("Expired")
}

model User {
  id                       String           @id @default(cuid())
  email                    String           @unique
  phone                    String?          @unique
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  outgoingRequests         PaymentRequest[] @relation("PaymentRequestSender")
  matchedIncomingRequests  PaymentRequest[] @relation("PaymentRequestRecipientMatch")

  @@map("users")
}

model PaymentRequest {
  id                     String               @id @default(cuid())
  senderUserId           String               @map("sender_user_id")
  recipientContactType   RecipientContactType @map("recipient_contact_type")
  recipientContactValue  String               @map("recipient_contact_value")
  recipientMatchedUserId String?              @map("recipient_matched_user_id")
  amountCents            Int                  @map("amount_cents")
  note                   String?
  status                 RequestStatus        @default(PENDING)
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  expiresAt              DateTime             @map("expires_at")
  paidAt                 DateTime?            @map("paid_at")
  declinedAt             DateTime?            @map("declined_at")
  cancelledAt            DateTime?            @map("cancelled_at")
  lastStatusChangedAt    DateTime             @map("last_status_changed_at")
  sender                 User                 @relation("PaymentRequestSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientMatchedUser   User?                @relation("PaymentRequestRecipientMatch", fields: [recipientMatchedUserId], references: [id], onDelete: SetNull)

  @@index([senderUserId, createdAt(sort: Desc)])
  @@index([recipientMatchedUserId, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@index([recipientContactValue, status])
  @@map("payment_requests")
}
