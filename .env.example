# Local development and Vercel should both provide these values.
# Keep NEXT_PUBLIC_APP_URL aligned with the environment you are testing.
DATABASE_URL="postgresql://user:password@host.neon.tech/lovie_p2p?sslmode=require"
SESSION_SECRET="replace-with-a-long-random-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: set this only when you want Playwright to target an already running
# local or deployed URL instead of booting `bun run dev` automatically.
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
